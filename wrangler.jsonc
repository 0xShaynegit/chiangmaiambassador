{
  "$schema": "https://json.schemastore.org/wrangler.json",
  "name": "chiangmaiambassador",
  "compatibility_date": "2026-06-17",
  "assets": {
    "directory": ".",
    "include": ["**/*.html", "**/*.css", "**/*.js", "**/*.json", "**/*.xml", "**/*.webp", "**/*.jpg", "**/*.png", "**/*.ico", "**/*.svg", "**/*.woff2", "_headers", "_redirects"],
    "exclude": [".git/**", "node_modules/**", ".md/**", ".*/**", "*.md"]
  }
}
