{
  "$schema": "node_modules/wrangler/config-schema.json",

  "name": "chiangmaiambassador",
  "compatibility_date": "2026-05-24",

  "assets": {
    "directory": "./",
    "include": ["**/*.html", "**/*.css", "**/*.js", "**/*.woff2", "**/*.svg", "**/*.json", "**/*.ico", "**/*.webp", "**/*.jpg", "**/*.png", "pagefind/**", "_headers"]
  }
}
